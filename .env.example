API_KEY = 'PUT YOUR API HERE'
FILE_ENCODING = 'utf-8'
# Optional timezone override (IANA name). Leave empty to use system timezone.
TODOIST_TIMEZONE = ''
# Optional runtime log level. Default is INFO; set DEBUG only when troubleshooting.
TODOIST_LOG_LEVEL = 'INFO'
# Optional AI backend selection for dashboard chat and AI task breakdown.
# Keep disabled for no AI imports/runtime startup. Backend modules are loaded only
# when TODOIST_AGENT_BACKEND directly selects them.
TODOIST_AGENT_BACKEND = 'disabled'
# Supported values: 'disabled', 'codex', 'triton_local'. Unsupported: remote
# OpenAI/Anthropic-compatible HTTP APIs, arbitrary local model ids outside the
# catalog, and write-capable agent workflows.
TODOIST_AGENT_DEVICE = 'cpu'
TODOIST_AGENT_MODEL_ID = 'Qwen/Qwen2.5-3B-Instruct'
TODOIST_AGENT_TRITON_URL = 'http://127.0.0.1:8003'
TODOIST_AGENT_TRITON_MODEL_NAME = 'todoist_llm'
# Triton uses TODOIST_AGENT_MODEL_ID too; only the Triton endpoint/name stay separate.
TODOIST_TRITON_BASE_IMAGE = 'nvcr.io/nvidia/tritonserver:23.08-py3'
# Python backend stub connection timeout. Increase this if a CPU model takes longer to initialize.
TODOIST_TRITON_STUB_TIMEOUT_SECONDS = '300'
TODOIST_TRITON_MAX_TOKENS = '384'
# 'auto' resolves to float16 on CUDA and float32 on CPU.
TODOIST_TRITON_MODEL_DTYPE = 'auto'
# Optional Codex backend settings.
TODOIST_AGENT_CODEX_MODEL = 'gpt-5.5'
TODOIST_AGENT_CODEX_SANDBOX = 'read-only'
TODOIST_AGENT_CODEX_APPROVAL = 'never'
TODOIST_AGENT_CODEX_REASONING_EFFORT = 'low'
HF_TOKEN = ''

# If you want to use experimental twitter integration
X_API_KEY = ''
X_API_KEY_SECRET = ''
X_ACCESS_TOKEN = ''
X_ACCESS_TOKEN_SECRET = ''
X_BAERER_TOKEN = ''
